---
import type { CollectionEntry } from "astro:content";

type Props = {
  entry: CollectionEntry<"blog"> | CollectionEntry<"projects">;
};

const { entry } = Astro.props as {
  entry: CollectionEntry<"blog"> | CollectionEntry<"projects">;
};

const date = entry.data.date.toLocaleDateString("en-CA");
---

<a
  href={`/${entry.collection}/${entry.id}`}
  class="not-prose group flex items-baseline gap-3 py-1.5 transition-colors duration-300 ease-in-out"
>
  <div
    class="flex min-w-0 flex-1 flex-col transition-transform duration-300 ease-in-out group-hover:translate-x-1 group-focus-visible:translate-x-1"
  >
    <div
      class="font-medium text-black/80 transition-colors duration-300 ease-in-out group-hover:text-black group-focus-visible:text-black dark:text-white/80 dark:group-hover:text-white dark:group-focus-visible:text-white"
    >
      <span
        class="mr-0 inline-block w-0 -translate-x-1 overflow-hidden text-black/40 opacity-0 transition-all duration-300 ease-in-out group-hover:mr-1.5 group-hover:w-2 group-hover:translate-x-0 group-hover:opacity-100 group-focus-visible:mr-1.5 group-focus-visible:w-2 group-focus-visible:translate-x-0 group-focus-visible:opacity-100 dark:text-white/40"
        aria-hidden="true">→</span
      >{entry.data.title}
    </div>
    <div class="truncate text-sm text-black/50 dark:text-white/50">
      {entry.data.description}
    </div>
  </div>
  <time
    datetime={entry.data.date.toISOString()}
    class="shrink-0 font-mono text-xs text-black/40 tabular-nums dark:text-white/40"
  >
    {date}
  </time>
</a>
