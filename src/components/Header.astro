---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { SITE } from "@consts";
---

<header transition:persist>
  <Container>
    <div class="grid grid-cols-[1fr_auto] items-center gap-4">
      <div class="flex items-center gap-3">
        <Link href="/" underline={false} group>
          <div class="flex items-center gap-2">
            <img
              src="/assets/images/avatar.png"
              alt="Mateusz Haligowski"
              width="40"
              height="40"
              class="size-10 rounded-full transition-transform duration-300 ease-in-out group-hover:scale-110 group-hover:-rotate-3"
              loading="eager"
            />
            <div class="text-lg leading-none font-semibold">
              {SITE.TITLE.toLocaleLowerCase()}
            </div>
          </div>
        </Link>
        <Link href="/blog" underline={false} group>
          <span
            class="inline-block text-base transition-transform duration-300 ease-in-out group-hover:-translate-y-0.5"
            >blog</span
          >
        </Link>
        <Link href="/" underline={false} group>
          <span
            class="inline-block text-base transition-transform duration-300 ease-in-out group-hover:-translate-y-0.5"
            >about me</span
          >
        </Link>
      </div>
      <nav
        aria-label="Primary"
        class="justify-self-end rounded-full border border-black/10 bg-neutral-50/80 px-2 py-1 text-sm font-medium shadow-sm shadow-black/5 backdrop-blur-md dark:border-white/15 dark:bg-neutral-950/60 dark:shadow-black/30"
      >
        <div class="flex items-center gap-1">
          <button
            id="magnifying-glass"
            aria-label="Search"
            class="grid size-8 place-items-center rounded-full transition-colors duration-300 ease-in-out hover:bg-black/5 hover:text-black focus-visible:bg-black/5 focus-visible:text-black dark:hover:bg-white/10 dark:hover:text-white dark:focus-visible:bg-white/10 dark:focus-visible:text-white"
          >
            <svg
              height="20"
              stroke-linejoin="round"
              viewBox="0 0 16 16"
              width="20"
              style="color: currentcolor;"
              ><path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M3.5 7C3.5 5.067 5.067 3.5 7 3.5C8.933 3.5 10.5 5.067 10.5 7C10.5 7.88461 10.1718 8.69256 9.63058 9.30876L9.30876 9.63058C8.69256 10.1718 7.88461 10.5 7 10.5C5.067 10.5 3.5 8.933 3.5 7ZM9.96544 11.0261C9.13578 11.6382 8.11014 12 7 12C4.23858 12 2 9.76142 2 7C2 4.23858 4.23858 2 7 2C9.76142 2 12 4.23858 12 7C12 8.11014 11.6382 9.13578 11.0261 9.96544L14.0303 12.9697L14.5607 13.5L13.5 14.5607L12.9697 14.0303L9.96544 11.0261Z"
                fill="currentColor"></path></svg
            >
          </button>
        </div>
      </nav>
    </div>
  </Container>
</header>
